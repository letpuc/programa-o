#include <stdio.h>

int main()
{
    int d1, m1, d2, m2;
    int diasnomes[]= {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31};
    int t1 = 0, t2 = 0;

    scanf("%d %d %d %d", &d1, &m1, &d2, &m2);

    for(int i = 0; i<m1-1; i++){
        t1 += diasnomes[i];
        /* se o m1 = 3 (março), o loop vai de i = 0 até i<2
        os meses são somados pois o += é um operador
        de atribuição composta com acumulação.
        */
    }
    t1 += d1;
    printf("t1 eh igual a: %d", t1);
    for(int i = 0; i<m2-1; i++){
        t2 += diasnomes[i];
    }
    t2 += d2;
    printf("t2 eh igual a: %d", t2);
    printf("falta %d dias", t2 - t1);

    return 0;
    }
