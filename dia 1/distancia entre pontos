#include <stdio.h>
#include <math.h>

int main()
{
    float x1, y1, x2, y2, distancia;

    printf("posicoes do ponto 1: \n");
    scanf("%f %f", &x1, &y1);
    printf("posicoes do ponto 2: \n");
    scanf("%f %f", &x2, &y2);

    distancia = sqrt(pow(x2 - x1, 2)+ pow(y2 - y1, 2));
    printf("\nA distancia entre as duas posicoes eh %.2f\n", distancia);

    return 0;
    }
