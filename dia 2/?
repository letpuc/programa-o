#include <stdio.h>
float mediaVet (float notas [], int tamanho){
    float soma, media;
    for (int i=0; i<tamanho; i++){
        soma += notas [i];
    }
    media = soma / tamanho;

    return media;
}

int main()
{
    int x, y;
    printf("Quantos alunos tem na turma: ");
    scanf("%d", &x);
    printf("Quantas avaliacoes foram feitas: ");
    scanf("%d", &y);
    
    float notas [x][y];
    for (int i=0; i<x; i++){
        for (int j=0; j<y; j++){
            scanf("%f", &notas[i][j]);
        }
    }

    float mediaA[x];
    for (int i=0; i<x; i++) {
        mediaA[i]= mediaVet (notas[i], y);
    }

    float mediaT = mediaVet (mediaA, x);

    for (int i = 0; i <x; i++){
        if (mediaA[i]>=6){
            printf("esse aluno foi aprovado e sua media eh %f\n", mediaA[i]);
        }else{
            printf("nao foi aprovado e media %f \n", mediaA[i]);
        }
    }
    printf("a media da turma foi %f", mediaT);
    return 0;
    }
